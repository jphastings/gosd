# Config fragment merged onto rock-4se-rk3399_defconfig.
#
# Setting the boot delay to zero removes the countdown so distro-boot
# proceeds straight to extlinux.conf. Holding a key during boot still drops
# to the U-Boot prompt (abort-with-keypress), so this does not remove the
# dev escape hatch -- it just removes the wait when nobody's pressing
# anything.
#
# Do NOT add CONFIG_BOOTSTD_FULL=n or similar here: distro-boot/bootstd must
# stay enabled, since that's what finds extlinux/extlinux.conf on the first
# FAT partition of the SD card.
CONFIG_BOOTDELAY=0

# Real hardware (bean gosd-sz6p, 2026-07-23) showed U-Boot scanning the
# global 'efi_mgr' bootmeth before extlinux on every boot: it probes 'mmc 1'
# (the empty onboard eMMC slot) for a Boot0000 EFI entry, fails, and prints
# ~6 lines -- "Cannot persist EFI variables without system partition",
# "Loading Boot0000 'mmc 1' failed", "EFI boot manager: Cannot load any
# image", "Boot failed (err=-14)" -- before falling through to the extlinux
# bootmeth that actually works. Costs ~0.46s and reads like a boot failure on
# serial. rock-4se-rk3399_defconfig doesn't set this itself -- it comes from
# boot/Kconfig's `config BOOTMETH_EFI_BOOTMGR` (default y, depends on
# EFI_BOOTMGR, which defaults y for arm64) -- verified against u-boot
# v2026.04's boot/Kconfig and lib/efi_loader/Kconfig, the tag this board's
# U-Boot is pinned to. Turning it off only drops the global efi_mgr scan and,
# as a side effect, the 'mmc 1' Boot0000 probe that produced the "Card did
# not respond to voltage select!" lines during that scan -- the empty-eMMC
# voltage-select warning that appears on its own during normal MMC bus
# enumeration (unrelated to efi_mgr) is left alone, it's legitimate probing
# of an empty socket. BOOTMETH_EXTLINUX (boot/Kconfig, `default y`,
# unconditional) and the BOOTMETH_DISTRO select chain that pulls it in are
# untouched, so extlinux discovery is unaffected.
# CONFIG_BOOTMETH_EFI_BOOTMGR is not set

# Same bring-up log showed "Reading from MMC(1)... *** Warning - bad CRC,
# using default environment" on every boot -- gosd images never run
# `saveenv`, so there's no valid saved environment to find and the warning is
# pure noise. rock-4se-rk3399_defconfig explicitly sets CONFIG_ENV_IS_IN_MMC=y
# (unlike radxa-zero-3e/nanopi-zero2's defconfigs, which don't set any
# ENV_IS_IN_* and so already resolve to ENV_IS_NOWHERE by Kconfig default --
# verified against their own env/Kconfig, no fragment change needed there).
# Turning CONFIG_ENV_IS_IN_MMC off here makes env/Kconfig's `ENV_IS_DEFAULT`
# (def_bool y when no ENV_IS_IN_* is set) select ENV_IS_NOWHERE automatically,
# so U-Boot starts straight from the compiled-in default environment,
# silently -- the same environment values it already falls back to today
# after the failed CRC check, just without reading MMC and printing the
# warning first. CONFIG_ENV_IS_NOWHERE=y is listed explicitly below for
# documentation even though the `select` makes it redundant.
# CONFIG_ENV_IS_IN_MMC is not set
CONFIG_ENV_IS_NOWHERE=y
