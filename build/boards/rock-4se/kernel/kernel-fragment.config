# Radxa ROCK 4SE (RK3399-T) trimmed mainline kernel — config fragment.
#
# Merged onto `make ARCH=arm64 defconfig` via scripts/kconfig/merge_config.sh,
# then finalized with `make olddefconfig` (mirrors radxa-zero-3e's
# build/boards/radxa-zero-3e/kernel/kernel-fragment.config - see that file's
# header for the general shape this one follows). The resulting full config
# is committed as kernel.config once a real `gosd build-kernel` run produces
# one (bean gosd-iosp; not yet done as of this fragment's authoring - see
# this board's README.md).
#
# Everything below is a hard requirement (all =y, CONFIG_MODULES=n — no
# loadable modules at all). Symbol names were verified against the pinned
# kernel source tree (v6.18.37) directly, not assumed from documentation —
# see bean gosd-iosp for the source URLs checked for each addition below.
# RK3399-specifics (SD controller, USB PHYs, Ethernet PHY) come from bean
# gosd-je2r's research findings.

# --- No loadable modules ---
# CONFIG_MODULES is not set

# --- Core / initramfs / vfat / net baseline (same as every other board) ---
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_ZSTD=y
# CONFIG_RD_GZIP is not set
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_TMPFS=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- SoC ---
CONFIG_ARCH_ROCKCHIP=y

# --- Storage: SD (dw_mmc) only. RK3399's eMMC controller is a different IP
# (Arasan SDHCI, CONFIG_MMC_SDHCI_OF_ARASAN) than radxa-zero-3e's RK3566
# DWC_MSHC eMMC (CONFIG_MMC_SDHCI_OF_DWCMSHC) - out of scope, SD-boot only
# (see bean gosd-je2r Finding #1). ---
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y

# --- exFAT: betamin's SSD is exFAT-formatted (host-native for USB
# mass-storage exposure). CONFIG_NLS_UTF8 is exFAT's own default iocharset
# (fs/exfat/Kconfig's EXFAT_DEFAULT_IOCHARSET); the codepage/iso8859 NLS
# modules above are kept from the baseline. ---
CONFIG_EXFAT_FS=y
CONFIG_NLS_UTF8=y

# --- NVMe/PCIe: betamin's SSD is NVMe over the M.2/PCIe port. ---
CONFIG_PCI=y
CONFIG_PCIE_ROCKCHIP_HOST=y
CONFIG_PHY_ROCKCHIP_PCIE=y
CONFIG_BLK_DEV_NVME=y

# --- Ethernet: rk3399-base.dtsi gmac -> RTL8211E (RGMII) PHY, confirmed via
# U-Boot's rock-4se-rk3399_defconfig (CONFIG_PHY_REALTEK=y) and Radxa's own
# docs (see bean gosd-je2r Finding #1). No Motorcomm alt PHY on this board
# (that was a radxa-zero-3e-family revision, not applicable here). ---
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_ROCKCHIP=y
CONFIG_REALTEK_PHY=y

# --- USB: DWC3 dual-role + gadget configfs stack, plus mass storage
# (betamin exposes a USB mass-storage gadget - bean gosd-k2fs's kernel
# dependency; the DTS-side dr_mode flip that makes a port gadget-capable is
# patches/0003-usb-dwc3-peripheral.patch). ---
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_DUAL_ROLE=y
# RK3399's USB PHYs: CONFIG_PHY_ROCKCHIP_INNO_USB2 (u2phy0/u2phy1, same
# driver as radxa-zero-3e) + CONFIG_PHY_ROCKCHIP_TYPEC (tcphy0/tcphy1, the
# RK3399 USB3 Type-C PHY). NOT CONFIG_PHY_ROCKCHIP_NANENG_COMBO_PHY - that
# symbol is RK3566-only (radxa-zero-3e's PHY), confirmed absent from
# drivers/phy/rockchip/Kconfig's RK3399 dependencies and wrong for this
# board (bean gosd-je2r Finding #1 - this is the single most important
# correction versus the radxa-zero-3e template).
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
CONFIG_PHY_ROCKCHIP_TYPEC=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
# Legacy mass-storage gadget (drivers/usb/gadget/legacy/, distinct from
# CONFIG_USB_CONFIGFS_MASS_STORAGE above) leaks in as =y from the arm64
# defconfig baseline. It auto-binds the UDC at boot with no backing file
# and contends with the configfs gadget stack GoSD actually uses. Hit on
# real hardware during bring-up (bean gosd-sz6p): serial log showed
# "no file given for LUN0" / "failed to start g_mass_storage: -22".
# CONFIG_USB_MASS_STORAGE is not set

# --- Peripherals ---
CONFIG_GPIO_ROCKCHIP=y
CONFIG_GPIO_CDEV=y
CONFIG_I2C=y
CONFIG_I2C_RK3X=y
CONFIG_SPI=y
CONFIG_SPI_ROCKCHIP=y
# CONFIG_SPI_SPIDEV: without CONFIG_MODULES this already lands =y via the
# arm64 defconfig baseline (same "defconfig fallback" shape noted in
# radxa-zero-3e's fragment), but it's listed here explicitly, and asserted
# in RequiredY, so a future kernel bump silently dropping it fails loudly
# instead of quietly losing /dev/spidev*.
CONFIG_SPI_SPIDEV=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y

# --- Cut: no WiFi driver compiled in (onboard brcm4329 WiFi/BT DT nodes
# exist but are out of this epic's scope - a follow-up WiFi/BT bean, per
# bean gosd-je2r Finding #1's side note), no sound/DRM, no debug info.
# DRM/rkvdec/ALSA stay cut - video is developer-recipe territory, not this
# stock trimmed kernel (fleet trim policy). ---
# CONFIG_WLAN is not set
# CONFIG_CFG80211 is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_BT is not set
CONFIG_DEBUG_INFO_NONE=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
