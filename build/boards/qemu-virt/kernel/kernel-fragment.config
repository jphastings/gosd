# qemu-virt (internal-only board — CI/local testing under
# qemu-system-aarch64 -M virt) trimmed mainline kernel — config fragment.
#
# Merged onto `make ARCH=arm64 defconfig` via scripts/kconfig/merge_config.sh,
# then finalized with `make olddefconfig` (see build.sh / docker-build.sh for
# the pinned source tag this was verified against — same tag as the Radxa
# Zero 3E kernel, so the two fragments stay diff-able against one source
# tree). The resulting full config is committed as kernel.config.
#
# Everything below is a hard requirement (all =y, CONFIG_MODULES=n — no
# loadable modules at all). Symbol names were verified against the pinned
# kernel source tree, not assumed from documentation.
#
# Output is Image only — no device tree blob is built or shipped: qemu's
# `-M virt` machine synthesizes its own DTB at boot time.

# --- No loadable modules ---
# CONFIG_MODULES is not set

# --- Core / initramfs / vfat / net baseline (same as the other boards) ---
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_ZSTD=y
# CONFIG_RD_GZIP is not set
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_TMPFS=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- Storage: virtio-blk, the FAT-partitioned image attached as /dev/vda ---
CONFIG_VIRTIO_BLK=y

# --- Network: virtio-net ---
CONFIG_VIRTIO_NET=y

# --- Virtio transports: qemu -M virt exposes virtio devices over both a
# --- generic PCIe host bridge (virtio-*-pci) and the mmio transport
# --- (virtio-*-device); support both so either -device flavor works. ---
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y

# --- Console: PL011 UART (qemu -M virt's ttyAMA0) ---
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# --- RTC: PL031 (qemu -M virt provides one; harmless, gives boots sane time) ---
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_PL031=y

# --- Cut: no real-hardware SoC platforms, no WiFi, no sound/media/DRM ---
# CONFIG_ARCH_ROCKCHIP is not set
# CONFIG_ARCH_BCM2835 is not set
# CONFIG_ARCH_BCM_IPROC is not set
# CONFIG_ARCH_BCMBCA is not set
# CONFIG_WLAN is not set
# CONFIG_CFG80211 is not set
# CONFIG_SOUND is not set
# CONFIG_SND is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_BT is not set
CONFIG_DEBUG_INFO_NONE=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
