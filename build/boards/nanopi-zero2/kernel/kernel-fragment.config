# FriendlyElec NanoPi Zero2 (RK3528A) trimmed mainline kernel — config fragment.
#
# Merged onto `make ARCH=arm64 defconfig` via scripts/kconfig/merge_config.sh,
# then finalized with `make olddefconfig` (see build.sh / docker-build.sh for
# the pinned source tag this was verified against). The resulting full config
# is committed as kernel.config.
#
# Everything below is a hard requirement (all =y, CONFIG_MODULES=n — no
# loadable modules at all). Symbol names were verified against the pinned
# kernel source tree (rk3528.dtsi, rk3528-nanopi-zero2.dts, and the matching
# driver of_device_id tables), not assumed from documentation or the
# Radxa Zero 3E fragment. See README.md for the full diff against that
# fragment and why each difference exists.

# --- No loadable modules ---
# CONFIG_MODULES is not set

# --- Core / initramfs / vfat / net baseline (same as every other board) ---
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_ZSTD=y
# CONFIG_RD_GZIP is not set
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_TMPFS=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- SoC ---
CONFIG_ARCH_ROCKCHIP=y

# --- Storage: microSD (dw_mmc, rk3288-dw-mshc compatible fallback) + eMMC
#     (dwcmshc, rk3588-dwcmshc compatible fallback) ---
# Identical to the Radxa Zero 3E: rk3528-nanopi-zero2.dts `sdmmc` node uses
# "rockchip,rk3528-dw-mshc","rockchip,rk3288-dw-mshc" and `sdhci` uses
# "rockchip,rk3528-dwcmshc","rockchip,rk3588-dwcmshc" — the same fallback
# compatibles the Radxa board's dw_mmc/dwcmshc nodes use, so the same driver
# set applies with no board-specific delta.
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI_OF_DWCMSHC=y

# --- Ethernet: rk3528-nanopi-zero2.dts gmac1 -> RGMII -> RTL8211F PHY ---
# dwmac-rk.c carries an explicit `{ .compatible = "rockchip,rk3528-gmac" }`
# entry (verified in the pinned tree), so — unlike USB below — this is fully
# wired up in mainline. The board's MDIO child node uses the generic
# "ethernet-phy-ieee802.3-c22" compatible (PHY driver binds by probed chip
# ID, not by DT compatible string); FriendlyElec's published spec sheet
# names the fitted chip as an RTL8211F, so only REALTEK_PHY is needed here
# (the Radxa Zero 3E fragment also carries MOTORCOMM_PHY for a
# board-revision variant that doesn't apply to this board).
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_ROCKCHIP=y
CONFIG_REALTEK_PHY=y

# --- USB: DELIBERATELY NOT A REQUIREMENT (no entries here) ---
# The bean text for this task assumed a dwc2/dwc3 USB gadget stack would be
# needed (mirroring the Radxa Zero 3E fragment's USB block). Bean gosd-vcae's
# verified research found this not to be the case: as of the pinned kernel
# tag, rk3528.dtsi has NO usb2host or usb3otg controller device node at all
# (only QoS-bus placeholder nodes and an unreferenced, disabled
# rk3528-naneng-combphy) — checked against every RK3528 board file shipped
# in the same kernel tree, not just this one. phy-rockchip-inno-usb2.c also
# has no rk3528 entry in its of_device_id table.
#
# Note the arm64 defconfig baseline this fragment merges onto ALREADY builds
# in the generic USB/dwc3/gadget-configfs stack (it does for the Radxa board
# too — that fragment's USB block mostly restates defconfig), so those
# symbols still appear =y in the generated kernel.config. On this board they
# bind to nothing at runtime. They are intentionally not listed here and not
# asserted by docker-build.sh: USB is not a requirement of this board's
# kernel at this tag. The dwc3 node (rockchip,rk3528-dwc3) is already merged
# on Linus's master (see bean gosd-vcae), so USB arrives with a future
# fleet-wide KERNEL_TAG bump — promote these to required entries then.

# --- Peripherals ---
CONFIG_GPIO_ROCKCHIP=y
CONFIG_GPIO_CDEV=y
CONFIG_I2C=y
CONFIG_I2C_RK3X=y
CONFIG_SPI=y
CONFIG_SPI_ROCKCHIP=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y

# --- Cut: no WiFi in-tree (M.2 module is out of scope for this Ethernet-
#     first epic), no sound/DRM/BT/GPU, no debug info ---
# CONFIG_WLAN is not set
# CONFIG_CFG80211 is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_BT is not set
CONFIG_DEBUG_INFO_NONE=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
