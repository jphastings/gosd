# Radxa Zero 3E (RK3566) trimmed mainline kernel — config fragment.
#
# Merged onto `make ARCH=arm64 defconfig` via scripts/kconfig/merge_config.sh,
# then finalized with `make olddefconfig` (see build.sh / docker-build.sh for
# the pinned source tag this was verified against). The resulting full config
# is committed as kernel.config.
#
# Everything below is a hard requirement (all =y, CONFIG_MODULES=n — no
# loadable modules at all). Symbol names were verified against the pinned
# kernel source tree, not assumed from documentation.

# --- No loadable modules ---
# CONFIG_MODULES is not set

# --- Core / initramfs / vfat / net baseline (same as the Pi Zero 2W task) ---
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_ZSTD=y
# CONFIG_RD_GZIP is not set
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_TMPFS=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- SoC ---
CONFIG_ARCH_ROCKCHIP=y

# --- Storage: SD (dw_mmc) + eMMC-capable SDHCI ---
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI_OF_DWCMSHC=y

# --- Ethernet: rk3566-radxa-zero-3e.dts gmac1 -> RTL8211F-CG (RGMII) PHY ---
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_ROCKCHIP=y
CONFIG_REALTEK_PHY=y
# Other Zero 3 family boards/revisions use a Motorcomm YT8531 PHY instead;
# cheap to include since it's a small, independent driver.
CONFIG_MOTORCOMM_PHY=y

# --- USB: DWC3 dual-role + gadget configfs stack ---
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_DUAL_ROLE=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
# The bean text names this CONFIG_PHY_ROCKCHIP_NANENG_COMBPHY; verified
# against drivers/phy/rockchip/Kconfig in the pinned tree, the actual mainline
# symbol is COMBO_PHY (not COMBPHY). Same driver Rockchip calls the "NaNeng
# COMBO PHY" (shared PCIe/USB3/SATA/QSGMII combo PHY block).
CONFIG_PHY_ROCKCHIP_NANENG_COMBO_PHY=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_RNDIS=y

# --- Peripherals ---
CONFIG_GPIO_ROCKCHIP=y
CONFIG_GPIO_CDEV=y
CONFIG_I2C=y
CONFIG_I2C_RK3X=y
CONFIG_SPI=y
CONFIG_SPI_ROCKCHIP=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y

# --- Cut: no WiFi (board has none), no sound/DRM/BT, no debug info ---
# CONFIG_WLAN is not set
# CONFIG_CFG80211 is not set
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_BT is not set
CONFIG_DEBUG_INFO_NONE=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
